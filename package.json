{
  "name": "terrariummarket",
  "private": true,
  "type": "module",
  "description": "Root-level scripts (build-index, validate, format) for the TerrariumMarket data repo. The Vue site has its own package.json under site/.",
  "scripts": {
    "build-index": "node scripts/build_index.mjs",
    "validate": "node scripts/build_index.mjs && echo 'OK'",
    "format": "prettier --write \"**/*.{md,yml,yaml,json,mjs,js}\"",
    "format:check": "prettier --check \"**/*.{md,yml,yaml,json,mjs,js}\""
  },
  "devDependencies": {
    "js-yaml": "^4.1.0",
    "prettier": "^3.3.0"
  }
}
