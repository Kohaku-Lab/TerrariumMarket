{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://terrariummarket.dev/schemas/registry.schema.json",
  "title": "TerrariumMarket aggregated index",
  "description": "Schema for the generated registry.yaml. CI builds this from entries/*/entry.yaml on every merge — do not edit by hand.",
  "type": "object",
  "required": ["schema_version", "generated", "packages"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "generated": {
      "type": "string",
      "format": "date-time",
      "description": "When the index was last regenerated by build-index.yml."
    },
    "source": {
      "type": "string",
      "format": "uri",
      "description": "Self-link to the canonical raw URL of this registry."
    },
    "maintainers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["github"],
        "additionalProperties": false,
        "properties": {
          "github": { "type": "string" },
          "name": { "type": "string" }
        }
      }
    },
    "packages": {
      "type": "array",
      "description": "Concatenated entries/*/entry.yaml, sorted by name.",
      "items": {
        "$ref": "entry.schema.json"
      }
    }
  }
}
